# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
.venv-1/
venv/
env/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── pytest / test cache ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
*.DS_Store

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Large data files (regenerated by pipeline) ─────────────────────────────────
data/raw/*.csv
data/processed/*.parquet
data/processed/*.csv

# ── Trained model artifacts (large binaries, regenerated by train_models.py) ──
artifacts/models/rf.joblib
artifacts/models/svm_rbf.joblib
artifacts/models/logreg.joblib
artifacts/models/mlp_torch.pt

# Keep the artifacts directory structure and lightweight CSVs/JSON
!artifacts/metrics_table.csv
!artifacts/anomaly_rates.csv
!artifacts/run_summary.json
!artifacts/plots/

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.lof
paper/*.lot
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz

# Keep the compiled PDF and source
!paper/main.pdf
!paper/main.tex
!paper/references.bib
!paper/compile.sh

# ── Backup folder (not needed in repo) ────────────────────────────────────────
Backup/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
